# ─── Django core ──────────────────────────────────────────────────────────────
# Generate a fresh key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# True for local dev, False in production.
# When False, the app enforces HTTPS, secure cookies, and HSTS,
# and refuses to start without ANTHROPIC_API_KEY.
DEBUG=True

# Comma-separated list of hostnames Django will accept.
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Optional in dev — if omitted, Django falls back
# to a local SQLite file (db.sqlite3). REQUIRED in production.
DATABASE_URL=postgresql://user:password@localhost:5432/nullbreach

# ─── Anthropic (Claude) ───────────────────────────────────────────────────────
# Get one at https://console.anthropic.com/ → Settings → API Keys.
# REQUIRED when DEBUG=False (the app raises ImproperlyConfigured at boot).
ANTHROPIC_API_KEY=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated frontend origins allowed to call the API.
CORS_ALLOWED_ORIGINS=http://localhost:5173
